{
  "name": "shuvo/smm-panel",
  "description": "Shuvo SMM Panel — Full-Stack Social Media Marketing Panel",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "ext-fileinfo": "*",
    "ext-curl": "*",
    "ext-json": "*",
    "phpmailer/phpmailer": "^6.9",
    "firebase/php-jwt": "^7.0",
    "pragmarx/google2fa": "^8.0",
    "vlucas/phpdotenv": "^5.6",
    "endroid/qr-code": "^5.0",
    "league/csv": "^9.14",
    "monolog/monolog": "^3.6",
    "nelexa/zip": "^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": {
      "SMMPanel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SMMPanel\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs-check": "phpcs --standard=PSR12 src/",
    "cs-fix": "phpcbf --standard=PSR12 src/",
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
