# =============================================================
# Shuvo SMM Panel — Environment Configuration
# Copy to .env and fill in all values before running
# NEVER commit .env to version control
# =============================================================

# ── App ───────────────────────────────────────────────────────
APP_NAME="Shuvo SMM Panel"
APP_ENV=production           # local | staging | production
APP_DEBUG=false
APP_URL=https://shuvosmm.com
APP_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_STRING

# ── Database ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shuvo_smm_panel
DB_USER=smm_user
DB_PASS=STRONG_DB_PASSWORD_HERE
DB_CHARSET=utf8mb4

# ── SMM API ───────────────────────────────────────────────────
SMM_API_URL=https://smmfm.com/api/v2
SMM_API_KEY=YOUR_PROVIDER_API_KEY_HERE

# ── SMTP Email ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
MAIL_FROM_NAME="Shuvo SMM Panel"
MAIL_FROM_EMAIL=noreply@shuvosmm.com

# ── Security ──────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/etc/ssl/smm/private.pem
JWT_PUBLIC_KEY_PATH=/etc/ssl/smm/public.pem
SESSION_LIFETIME=86400       # seconds (24h)
REMEMBER_ME_DAYS=30

# ── hCaptcha ──────────────────────────────────────────────────
HCAPTCHA_SITE_KEY=YOUR_HCAPTCHA_SITE_KEY
HCAPTCHA_SECRET=YOUR_HCAPTCHA_SECRET

# ── Payments ──────────────────────────────────────────────────
BKASH_NUMBER=01XXXXXXXXX
BKASH_TYPE=Personal

NAGAD_NUMBER=01XXXXXXXXX

ROCKET_NUMBER=01XXXXXXXXX

USDT_TRC20_ADDRESS=YOUR_TRC20_WALLET_ADDRESS
USDT_ERC20_ADDRESS=YOUR_ERC20_WALLET_ADDRESS

BINANCE_PAY_ID=YOUR_BINANCE_PAY_ID

# ── Cache ─────────────────────────────────────────────────────
CACHE_DRIVER=file            # file | redis | memcached
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# ── Storage ───────────────────────────────────────────────────
UPLOAD_MAX_SIZE=5            # MB
UPLOAD_PATH=/var/www/shuvosmm/storage/uploads

# ── Tawk.to Live Chat ─────────────────────────────────────────
TAWKTO_PROPERTY_ID=
TAWKTO_WIDGET_ID=

# ── Admin ─────────────────────────────────────────────────────
ADMIN_IP_WHITELIST=           # Comma-separated IPs, empty = disabled
ADMIN_2FA_REQUIRED=true

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warning | error | critical
LOG_CHANNEL=file             # file | database | both
